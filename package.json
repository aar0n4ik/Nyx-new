{
	"name": "nyx",
	"version": "0.2.0",
	"description": "Nyx — полностью локальный, автономный и безопасный ИИ-агент (Edge AI), на движке QVAC (Tether).",
	"author": {
		"name": "Bohdan Reva",
		"email": "bohdanreva00@gmail.com"
	},
	"type": "module",
	"main": "electron/main.cjs",
	"scripts": {
		"start": "node server.js",
		"electron": "electron .",
		"patch:download": "node patch-download.js",
		"dist": "electron-builder --win nsis",
		"pack": "electron-builder --dir"
	},
	"build": {
		"appId": "app.nyx.desktop",
		"productName": "Nyx",
		"asar": true,
		"files": [
			"electron/**",
			"server.js",
			"src/**",
			"public/**",
			"!**/*.map"
		],
		"directories": { "buildResources": "build", "output": "dist" },
		"win": {
			"target": ["nsis"],
			"artifactName": "Nyx-Setup.exe"
		},
		"nsis": {
			"oneClick": false,
			"perMachine": false,
			"allowElevation": true,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true
		}
	},
	"engines": {
		"node": ">=22.17"
	},
	"dependencies": {
		"@qvac/sdk": "^0.14.0",
		"systeminformation": "^5.22.0"
	},
	"devDependencies": {
		"electron": "^30.0.0",
		"electron-builder": "^24.13.3"
	}
}
