{
  "name": "nyx",
  "version": "0.7.0",
  "type": "module",
  "description": "Verifiable, on-device edge-AI copilot built on the QVAC SDK, with a Zero-Trust Bitfinex (USD₮) trading assistant",
  "license": "Apache-2.0",
  "scripts": {
    "setup": "node scripts/setup-models.js && node -e \"import('./src/rag.js').then(m=>m.buildIndex())\"",
    "model": "npm i @qvac/sdk && node scripts/setup-models.js",
    "keys": "node scripts/gen-keys.js",
    "start": "node server.js",
    "bench": "node scripts/bench.js",
    "verify": "node verify.js",
    "demo": "bash scripts/demo.sh",
    "hwproof": "node scripts/hwproof.js",
    "evidence": "node scripts/evidence.js",
    "electron": "electron .",
    "dist": "electron-builder --win --publish never"
  },
  "dependencies": {
    "@qvac/sdk": "^0.13.5"
  },
  "optionalDependencies": {
    "systeminformation": "^5.22.0"
  },
  "main": "electron/main.cjs",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.aaron4ik.nyx",
    "productName": "Nyx",
    "copyright": "© 2026 Bohdan (AARON4IK)",
    "asar": false,
    "compression": "maximum",
    "files": [
      "electron/**/*",
      "public/**/*",
      "src/**/*",
      "scripts/**/*",
      "server.js",
      "verify.js",
      "cli.js",
      "remote-apis.json",
      "package.json"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico",
      "artifactName": "Nyx-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "author": {
    "name": "Bohdan (AARON4IK)",
    "email": "bohdanreva00@gmail.com"
  }
}
